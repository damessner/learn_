generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String             @id @default(uuid())
  username         String             @unique
  passwordHash     String
  role             String             // "ADMIN", "TEACHER", or "STUDENT"
  active           Boolean            @default(false)
  createdAt        DateTime           @default(now())

  // AI helping contingents (quotas)
  dailyLimit            Int      @default(160)
  dailyRemaining        Int      @default(160)
  lastDailyReset        DateTime @default(now())
  windowInputTimestamps String   @default("[]")
  windowQuizTimestamps  String   @default("[]")
  
  // Relations
  classroomsTaught  Classroom[]        @relation("TeacherClassrooms")
  classroomsJoined  ClassroomStudent[]
  submissions       Submission[]
  aloysConversations AloysConversation[]
  createdExercises  Exercise[]         @relation("CreatorExercises")
  ratings           Rating[]
}

model Classroom {
  id               String             @id @default(uuid())
  name             String
  joinCode         String             @unique
  teacherId        String
  createdAt        DateTime           @default(now())
  aiDiagnostic     String?
  aiDiagnosticDate DateTime?

  // Relations
  teacher           User               @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  students          ClassroomStudent[]
  assignments       Assignment[]
  courseAssignments CourseAssignment[]
}

model ClassroomStudent {
  classroomId String
  studentId   String
  joinedAt    DateTime @default(now())

  // Relations
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([classroomId, studentId])
}

model Course {
  id          String     @id @default(uuid())
  title       String
  description String     @default("")
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  exercises      Exercise[]
  courseAssignments CourseAssignment[]
}

model Exercise {
  id              String            @id // matches directory name
  title           String
  description     String
  type            String            // "multiple-choice", "drag-drop", "gap-fill", "categorization", "tiptoi"
  courseId        String?
  order           Int               @default(0) // position within course
  updatedAt       DateTime          @default(now())
  pendingDeletion Boolean           @default(false)
  tags            String            @default("")
  badgeName       String?
  badgeEmoji      String?
  creatorId       String?

  // Relations
  course          Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  creator         User?             @relation("CreatorExercises", fields: [creatorId], references: [id], onDelete: SetNull)
  assignments     Assignment[]
  liveSessions    LiveQuizSession[]
  ratings         Rating[]
}

model Assignment {
  id                String            @id @default(uuid())
  classroomId      String
  exerciseId       String
  dueDate           DateTime?
  createdAt         DateTime          @default(now())
  courseAssignmentId String?

  // Relations
  classroom        Classroom         @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  exercise         Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  submissions     Submission[]
  courseAssignment CourseAssignment? @relation(fields: [courseAssignmentId], references: [id], onDelete: SetNull)
}

model CourseAssignment {
  id          String   @id @default(uuid())
  classroomId String
  courseId    String
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  // Relations
  classroom   Classroom   @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignments Assignment[]
}

model Submission {
  id             String     @id @default(uuid())
  assignmentId   String
  studentId      String
  answersJson    String     // JSON string of submitted answers
  score          Float      // raw percentage, e.g., 85.0
  effectiveScore Float      @default(0) // score after attempt-number multiplier
  attemptNumber  Int        @default(1) // 1st attempt, 2nd, 3rd, etc.
  completed      Boolean    @default(true)
  completedAt    DateTime   @default(now())
  feedback       String?
  teacherScore   Float?
  reviewedAt     DateTime?
  draft          Boolean    @default(false)

  // Relations
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model LiveQuizSession {
  id                 String            @id @default(uuid())
  exerciseId         String
  hostId             String
  pin                String            // e.g. 6-digit session pin
  status             String            // LOBBY, QUESTION, SHOW_CORRECT, LEADERBOARD, FINISHED
  currentQuestionIdx Int               @default(0)
  questionStartedAt  DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  // Relations
  exercise           Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  participants       LiveParticipant[]
  responses          LiveResponse[]
}

model LiveParticipant {
  id        String          @id @default(uuid())
  sessionId String
  userId    String?         // Optional: links to a registered student account
  name      String          // Student nickname or full name
  score     Int             @default(0)
  joinedAt  DateTime        @default(now())
  
  // Relations
  session   LiveQuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses LiveResponse[]
}

model LiveResponse {
  id            String          @id @default(uuid())
  sessionId     String
  participantId String
  questionIdx   Int
  answerJson    String          // JSON array/string of answers
  isCorrect     Boolean
  points        Int             @default(0)
  answeredAt    DateTime        @default(now())
  
  // Relations
  session       LiveQuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant   LiveParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model AloysConversation {
  id          String         @id @default(uuid())
  studentId   String
  title       String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  // Relations
  student     User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messages    AloysMessage[]
}

model AloysMessage {
  id             String            @id @default(uuid())
  conversationId String
  role           String            // "user" or "assistant"
  content        String
  type           String            @default("CHAT") // "CHAT", "LEARN_TEXT", "LEARN_QUESTIONS", "LEARN_ANSWERS"
  metadataJson   String?           // For options or extra grading details
  createdAt      DateTime          @default(now())
  
  // Relations
  conversation   AloysConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Rating {
  id          String   @id @default(uuid())
  exerciseId  String
  teacherId   String
  stars       Int      // 1 to 5
  createdAt   DateTime @default(now())

  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  teacher     User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, teacherId])
}

model WordOfTheDay {
  date        String   @id // "YYYY-MM-DD"
  word        String
  translation String
  definition  String
  example     String
  mnemonic    String
  createdAt   DateTime @default(now())
}
